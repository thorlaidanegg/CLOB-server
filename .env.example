ROLE=all
LOG_LEVEL=info
ENVIRONMENT=local
POSTGRES_DSN=postgres://clob:clob@localhost:5432/clob?sslmode=disable
KAFKA_BROKERS=localhost:9092
REDIS_ADDR=localhost:6379
MARKETS=BTC-USD,ETH-USD
ENGINE_GRPC_PORT=50051
HTTP_PORT=8080
ENGINE_GRPC_ADDR=localhost:50051
RATE_LIMIT_RPM=300
RATE_LIMIT_WS_RPS=50
NODE_POOL_SIZE=100000
ADMIN_BOOTSTRAP_KEY=clob_admin_devbootstrapkeylocal

# Crash recovery for the engine role.
#   replay (default): rebuild each market's book from the event-log checkpoint
#                     (maintained by ROLE=booksnapshot), folding the Kafka tail.
#   cancel:           cancel all open orders and release reservations on restart.
ENGINE_RECOVERY=replay

# gRPC TLS between gateway and engine (optional; plaintext if unset — fine inside a VPC).
# Set cert+key on the engine, CA on the gateway.
GRPC_TLS_CERT_FILE=
GRPC_TLS_KEY_FILE=
GRPC_TLS_CA_FILE=

# CORS allowed origins for browser frontends, comma-separated. Empty = disabled.
# Non-browser clients (bots, mobile, curl) are unaffected. Use "*" to allow any origin.
CORS_ALLOWED_ORIGINS=
