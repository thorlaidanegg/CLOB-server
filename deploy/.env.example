# Copy to .env and fill in. Used by deploy/docker-compose.yml.

# The public address Caddy serves on. A bare domain turns on automatic HTTPS
# (point its DNS A record at this VM and open ports 80+443). Use ":80" to serve
# plain HTTP against a raw IP while testing.
SITE_ADDRESS=clob.example.com

# Secrets — CHANGE THESE. JWT_SECRET should be long and random
# (e.g. `openssl rand -hex 32`). ADMIN_BOOTSTRAP_KEY is your master API key:
# it can create markets, credit users, and grant inventory.
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_BOOTSTRAP_KEY=clob_admin_change_me
POSTGRES_PASSWORD=change-me

# Markets created on first boot (comma-separated). You can also create more from
# the UI at runtime ("Create market").
MARKETS=BTC-USD,ETH-USD,SOL-USD

# Virtual credits handed to each new signup.
SIGNUP_CREDITS=100000.00

# ── Optional bots (docker compose --profile bots up -d) ──────────────────────
# Two trader API keys minted in the UI (different accounts so quotes cross).
BOT_MARKET=BTC-USD
MAKER_KEY=
TAKER_KEY=
